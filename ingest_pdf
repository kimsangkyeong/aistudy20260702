import os
import glob
from dotenv import load_dotenv
from langchain_community.document_loaders import PyPDFLoader
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_community.vectorstores import Chroma
from model_factory import ModelFactory

def run_multi_pdf_ingest(data_dir: str):
    """
    지정한 디렉토리 내의 모든 PDF 파일을 찾아 텍스트를 추출하고,
    하나의 Chroma Vector DB로 통합 적재합니다.
    """
    # 1. 특정 폴더 안의 모든 PDF 파일 목록 검색 (*.pdf)
    search_path = os.path.join(data_dir, "*.pdf")
    pdf_files = glob.glob(search_path)
    
    if not pdf_files:
        print(f"[오류] '{data_dir}' 폴더 내에 학습시킬 PDF 파일이 존재하지 않습니다.")
        print("💡 팁: ./data 폴더를 만들고 Red Hat 가이드 PDF 파일들을 넣어주세요.")
        return

    print(f"[⚙️] 총 {len(pdf_files)}개의 PDF 문서가 감지되었습니다.")
    print(f"🕵️‍♂️ 감지된 파일 목록: {[os.path.basename(f) for f in pdf_files]}")
    print("-" * 50)

    all_chunks = []
    text_splitter = RecursiveCharacterTextSplitter(chunk_size=900, chunk_overlap=150) [cite: 207]

    # 2. 각 PDF 파일을 순회하며 텍스트 추출 및 청크 분할
    for index, pdf_path in enumerate(pdf_files, 1):
        file_name = os.path.basename(pdf_path)
        print(f"[*] [{index}/{len(pdf_files)}] '{file_name}' 파싱 시작...")
        
        try:
            loader = PyPDFLoader(pdf_path) [cite: 207]
            pages = loader.load() [cite: 207]
            
            # 메타데이터 보강 (어느 파일에서 나온 정보인지 출처 추적 용이성 강화)
            for page in pages:
                page.metadata["source_file"] = file_name
                
            chunks = text_splitter.split_documents(pages) [cite: 207]
            all_chunks.extend(chunks)
            print(f"    ➔ 파싱 완료: {len(pages)} 페이지 / 생성된 청크 {len(chunks)}개")
            
        except Exception as e:
            print(f"⚠️ [{file_name}] 처리 중 오류가 발생하여 건너뜁니다. 에러명: {e}")
            continue

    print("-" * 50)
    print(f"[Content] 모든 PDF 파싱 완료. 총 통합 청크 수: {len(all_chunks)}개")

    # 3. 현재 가동 환경에 연동된 임베딩 모델 로드 (Azure 또는 Gemini 자동 전환) [cite: 207]
    load_dotenv() [cite: 207]
    embeddings = ModelFactory.get_embeddings() [cite: 207]
    db_path = os.getenv("CHROMA_DB_PATH", "./chroma_db") [cite: 207]

    print(f"[*] 로컬 Chroma DB 빌드 및 저장 중... (경로: {db_path})") [cite: 207]
    
    # 여러 개의 문서 조각을 한 번에 Vector DB에 적재 및 퍼시스트
    vector_store = Chroma.from_documents(
        documents=all_chunks,
        embedding=embeddings,
        persist_directory=db_path
    )
    
    print(f"[🎉 완료] 모든 OCP 기술 PDF 가이드북이 '{db_path}'에 통합 저장되었습니다! [cite: 207]")

if __name__ == "__main__":
    # 데이터 폴더 경로 설정 및 자동 생성 예외 처리 
    target_dir = "./data"
    os.makedirs(target_dir, exist_ok=True) [cite: 211]
    
    # 다중 PDF 가동 파이프라인 트리거
    run_multi_pdf_ingest(target_dir)